docs_CN/AOEM-FFI/AOEM-FFI-BETA08-V2-RESEAL-RAW-2026-03-02.csv
docs_CN/INDEX.md
# Local-only VS Code settings
.vscode/
*.code-workspace

# AOEM runtime data (local benchmark/persistence outputs)
aoem/data/
aoem/variants/*/config/aoem-runtime-profile.json

# AOEM bundle: track full FFI runtime set (windows + linux + sidecars)
aoem/**
!aoem/
!aoem/INSTALL-INFO.txt
!aoem/bin/
aoem/bin/**
!aoem/bin/aoem_ffi.dll
!aoem/plugins/
aoem/plugins/**
!aoem/plugins/*.dll
!aoem/include/
aoem/include/**
!aoem/include/aoem.h
!aoem/manifest/
aoem/manifest/**
!aoem/manifest/aoem-manifest.json
!aoem/config/
aoem/config/**
!aoem/config/aoem-runtime-profile.json
!aoem/linux/
aoem/linux/**
!aoem/linux/bin/
aoem/linux/bin/**
!aoem/linux/bin/libaoem_ffi.so
!aoem/linux/plugins/
aoem/linux/plugins/**
!aoem/linux/plugins/*.so
!aoem/linux/include/
aoem/linux/include/**
!aoem/linux/include/aoem.h

# Never track local build side-products under AOEM bundle
aoem/**/*.pdb
aoem/**/*.lib
aoem/**/*.exp
aoem/**/*.d

# Local release pack outputs
artifacts/

# Local experimental sandbox (never push)
beta_local/
experiments_local/

# Runtime/cache/tool state (local only)
.git/
.venv/
.idea/
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.DS_Store
node_modules/
__pycache__/
.cargo/registry/
.cargo/git/
.cargo-local/
.cargo-local-*/
.cargo-home/
cargo-target/
cargo-target-*/
